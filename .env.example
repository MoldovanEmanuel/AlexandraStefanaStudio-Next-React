# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/alexandrastefana_studio"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-to-a-random-secret-at-least-32-chars"
JWT_EXPIRY="7d"

# AWS S3
AWS_REGION="eu-central-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_S3_BUCKET="alexandrastefana-studio-media"
CLOUDFRONT_DOMAIN="your-distribution.cloudfront.net"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
CONTACT_MAIL_TO="contact@alexandrastefana.studio"
MAIL_FROM_NAME="Alexandra Stefana Studio"

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Admin seed (for db:seed script)
ADMIN_SEED_EMAIL="admin@alexandrastefana.studio"
ADMIN_SEED_PASSWORD="change-me-before-seeding"
